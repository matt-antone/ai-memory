# Copy this file to `.env` (or export the variables in your shell) and fill in real values.

# Shared MCP host settings
MEMORY_MCP_URL="https://your-project-ref.supabase.co/functions/v1/memory-mcp"
MEMORY_MCP_ACCESS_KEY=""

# Optional: set when using scoped client auth instead of a shared admin key.
# MEMORY_MCP_CLIENT_ID=""

# Optional: only needed if smoke tests should hit a different deployed endpoint.
# MEMORY_MCP_SMOKE_URL="https://your-project-ref.supabase.co/functions/v1/memory-mcp"

# Optional: convenience overrides for helper scripts.
CLAUDE_MCP_SCOPE="project"
CLAUDE_MCP_SERVER_NAME="ai-memory"
CODEX_MCP_SERVER_NAME="ai-memory"
CURSOR_MCP_SERVER_NAME="ai-memory"

# Supabase edge function secrets / runtime configuration
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-me"

# Choose one auth strategy for the deployed edge function:
# 1) a single shared admin key via MEMORY_MCP_ACCESS_KEY above, or
# 2) scoped clients JSON.
# Advanced: if you truly need multiple admin keys, the runtime also supports
# MEMORY_MCP_ACCESS_KEYS as a comma-separated override.
MEMORY_MCP_CLIENTS_JSON='[
  {
    "client_id": "codex-desktop",
    "secret": "replace-me",
    "namespace": {
      "scope": "workspace",
      "workspace_id": "/Users/matthewantone/CurrentDevProjects/AI/ai-memory"
    }
  }
]'

# Optional runtime tuning for the deployed edge function.
MEMORY_RATE_LIMIT_WINDOW_MS="60000"
MEMORY_RATE_LIMIT_MAX_REQUESTS="120"

# Optional: override integration-test credentials only when they differ from the
# shared Supabase values above.
# SUPABASE_INTEGRATION_URL="https://your-project-ref.supabase.co"
# SUPABASE_INTEGRATION_SERVICE_ROLE_KEY="replace-me"
