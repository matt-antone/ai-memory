{
  "theme": "dark",
  "mcpServers": {
    "existing-server": {
      "type": "http",
      "url": "https://existing.test/mcp",
      "headers": {
        "authorization": "Bearer keep"
      }
    },
    "ai_memory": {
      "type": "http",
      "url": "https://example.test/memory",
      "headers": {
        "x-memory-key": "${env:MEMORY_MCP_ACCESS_KEY}",
        "x-memory-client-id": "client-a"
      },
      "envFile": "${workspaceFolder}/.env"
    }
  },
  "featureFlags": {
    "showExperimentalMcp": true
  }
}
